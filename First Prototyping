unsigned long btnA_pt=0,btnB_pt=0;
bool btnA_held=false,btnB_held=false,btnA_proc=false,btnB_proc=false;
const unsigned long LONG_PRESS=700, DEBOUNCE=50;

void handleBtn(int pin,unsigned long &pt,bool &held,bool &proc,bool &sOut,bool &lOut){
  sOut=false; lOut=false;
  if(digitalRead(pin)==LOW){
    if(!held){held=true;proc=false;pt=millis();}
    else if(!proc&&millis()-pt>=LONG_PRESS){lOut=true;proc=true;}
  } else {
    if(held){if(!proc&&millis()-pt>=DEBOUNCE)sOut=true; held=false;proc=false;}
  }
}


