// ════════════════════════════════════════════════════════════
//  WEB HANDLERS
// ════════════════════════════════════════════════════════════
void handleRoot()       { server.send_P(200,"text/html",TIME_HTML); }
void handleSetupPage()  { server.send_P(200,"text/html",SETUP_HTML); }
void handleAlarmsPage() { server.send_P(200,"text/html",ALARMS_HTML); }
void handleNotFound()   { server.sendHeader("Location","http://192.168.4.1",true); server.send(302,"text/plain",""); }

// TIME SYNC — now receives epoch (UTC-based local) + tz offset
void handleSetTime() {
  if (!server.hasArg("epoch")) { server.send(400,"text/plain","Missing epoch"); return; }

  // epoch from browser = local epoch (built from local date/time components)
  // tz = offset in minutes (e.g. 60 for UTC+1)
  // We store epoch as-is (local time) — decodeEpoch uses gmtime_r which gives correct local time
  time_t epoch = (time_t)server.arg("epoch").toInt();
  int32_t tzMin = server.hasArg("tz") ? server.arg("tz").toInt() : 0;
  g_tzOffsetSec = tzMin * 60;

  // Store to RTC if available — RTC stores local time directly
  if (timeSource==TS_RTC || rtc.begin()) {
    DateTime dt(epoch);   // RTClib treats this as-is
    rtc.adjust(dt);
    timeSource = TS_RTC;
  }
  swEpoch  = epoch;
  swMillis = millis();
  if (timeSource==TS_NONE) timeSource=TS_SOFTWARE;

  // Persist timezone for future reboots
  timeSynced = true;
  prefs.begin("sm",false); prefs.putInt("tz",(int)g_tzOffsetSec); prefs.end();

  server.send(200,"text/plain","OK");
}

// CONFIG JSON
void handleConfigJson() {
  String j="{\"s\":["; j+=sessionMins[0];j+=",";j+=sessionMins[1];j+=",";j+=sessionMins[2];j+="],\"exercises\":[";
  for(int i=0;i<numExercises;i++){
    if(i>0)j+=","; j+="{\"name\":\"";
    for(int c=0;exList[i].name[c];c++){char ch=exList[i].name[c];if(ch=='"')j+="\\\"";else j+=ch;}
    j+="\",\"dur\":";j+=exList[i].durationSec;j+="}";
  }
  j+="]}";
  server.send(200,"application/json",j);
}

