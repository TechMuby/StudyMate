void handleNotFound()  { server.sendHeader("Location","http://192.168.4.1",true); server.send(302,"text/plain",""); }

void handleSetTime() {
  if (!server.hasArg("epoch")) { server.send(400,"text/plain","Missing epoch"); return; }
  time_t epoch=(time_t)server.arg("epoch").toInt();
  if (timeSource==TS_RTC||rtc.begin()) { rtc.adjust(DateTime((uint32_t)epoch)); timeSource=TS_RTC; }
  swEpoch=epoch; swMillis=millis();
  if (timeSource==TS_NONE) timeSource=TS_SOFTWARE;
  timeSynced=true;
  server.send(200,"text/plain","OK");
}

// GET /config.json — returns current runtime config as JSON
void handleConfigJson() {
  String json = "{\"s\":[";
  json += sessionMins[0]; json += ",";
  json += sessionMins[1]; json += ",";
  json += sessionMins[2]; json += "],\"exercises\":[";
  for (int i=0; i<numExercises; i++) {
    if (i>0) json += ",";
    json += "{\"name\":\"";
    // escape quotes in name
    for (int c=0; exList[i].name[c]; c++) {
      char ch = exList[i].name[c];
      if (ch=='"') json += "\\\""; else json += ch;
    }
    json += "\",\"dur\":"; json += exList[i].durationSec; json += "}";
  }
  json += "]}";
  server.send(200,"application/json",json);
}

// GET /defaults — returns factory defaults as JSON (does NOT save)
void handleDefaults() {
  const char* dNames[] = {
    "Get Ready!","Jack Squats","Push-Ups","Caterpillars",
    "Inch Worms","Elbow Plank","Cat Stretch","Wats Up Dawg",
    "Heel Tap Crunch","Hip Thrust","Squat+Calf Raise",
    "Eagle Walks","Upright Plank","Hamstring Stretch",
    "Superman Strokes","Neg. Push-Ups","Hip Stretch Lunge",
    "Squat Taps","Jumping Jacks"
  };
  const int dDur[]={27,30,30,30,30,30,30,30,30,30,60,30,30,60,30,30,30,30,30};
  String json="{\"s\":[10,30,60],\"exercises\":[";
  for (int i=0;i<19;i++){
    if(i>0)json+=",";
    json+="{\"name\":\""; json+=dNames[i]; json+="\",\"dur\":"; json+=dDur[i]; json+="}";
  }
  json+="]}";
  server.send(200,"application/json",json);
}

// POST /save — receives JSON, parses, saves to flash, restarts app state
void handleSave() {
  if (!server.hasArg("plain")) { server.send(400,"text/plain","No body"); return; }
  String body = server.arg("plain");

  // Simple JSON parser — no external library needed
  // Format: {"s":[10,30,60],"exercises":[{"name":"...","dur":30},...]}

  // Parse session minutes
  int si = body.indexOf("\"s\":[");
  if (si >= 0) {
    si += 5;
    for (int k=0; k<3; k++) {
      int end = body.indexOf(k<2?',':']', si);
      if (end<0) break;
      int val = body.substring(si,end).toInt();
      if (val>=1&&val<=180) sessionMins[k]=val;
      si = end+1;
    }
  }

  // Parse exercises
  int exCount = 0;
  int pos = body.indexOf("\"exercises\":[");
  if (pos >= 0) {
    pos += 13;
    while (exCount < MAX_EXERCISES) {
      int objStart = body.indexOf('{', pos);
      if (objStart < 0) break;
      int objEnd   = body.indexOf('}', objStart);
      if (objEnd   < 0) break;
      String obj   = body.substring(objStart, objEnd+1);

      // name
      int ni = obj.indexOf("\"name\":\"");
      String nm = "Exercise";
      if (ni >= 0) {
        ni += 8;
        int ne = ni;
        while (ne < (int)obj.length() && !(obj[ne]=='"' && obj[ne-1]!='\\')) ne++;
        nm = obj.substring(ni, ne);
        nm.replace("\\\"","\"");
      }
      // dur
      int di = obj.indexOf("\"dur\":");
      int dur = 30;
      if (di >= 0) {
        di += 6;
        int de = di;
        while (de<(int)obj.length()&&(obj[de]>='0'&&obj[de]<='9')) de++;
        dur = obj.substring(di,de).toInt();
        if (dur<5)  dur=5;
        if (dur>600) dur=600;
      }

      strncpy(exList[exCount].name, nm.c_str(), MAX_NAME_LEN);
      exList[exCount].name[MAX_NAME_LEN]='\0';
      exList[exCount].durationSec = dur;
      exCount++;
      pos = objEnd + 1;
    }
  }

  if (exCount > 0) numExercises = exCount;
  computeStartTimes();
  saveConfig();
  setupSaved = true;

  server.send(200,"text/plain","OK");
}


