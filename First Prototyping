//  ALARM SYSTEM
// ════════════════════════════════════════════════════════════
// Alarm type:
//   0 = Once   (fires once at specified date+time, then disables itself)
//   1 = Daily  (fires every day at HH:MM)
//   2 = Weekly (fires on specified day-of-week at HH:MM)

struct Alarm {
  bool    enabled;
  uint8_t type;       // 0=once 1=daily 2=weekly
  uint8_t hour;
  uint8_t minute;
  uint8_t dayOfWeek;  // 0=Sun..6=Sat  (used for weekly & once)
  char    label[ALARM_LABEL_LEN + 1];
};

Alarm   alarms[MAX_ALARMS];
int     numAlarms = 0;
bool    alarmFiring = false;
int     firingAlarmIdx = -1;
unsigned long alarmStartMs = 0;
