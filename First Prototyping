//  SYNC DONE
//
//  ┌────────────────────┐
//  │  ---  Synced!  --- │
//  │                    │
//  │      ✓  Done!      │
//  │   Starting clock   │
//  └────────────────────┘
// ─────────────────────────────────────────────────────────────
void drawSyncDone() {
  slots_Sync();
  lcd.clear();
  printCenter(0, "---  Synced!  ---");
  lcd.setCursor(6, 2);
  lcd.write(6);   // ✓ checkmark
  lcd.print("  All good!");
  printCenter(3, "Starting clock...");
}

// ─────────────────────────────────────────────────────────────
//  HOME CLOCK
//
//  ┌────────────────────┐
//  │⊙ Wed, 14 May '25   │
//  │                    │
//  │     10 : 45 AM     │
//  │  --------------------  │
//  └────────────────────┘
//
//  Row 2 is intentionally blank — gives the time room to breathe.
//  Row 3 is a soft separator + icon hint (no seconds shown).
// ─────────────────────────────────────────────────────────────
void drawHomeClock() {
  decodeEpoch(nowEpoch());

  lcd.clear();

  // ── Row 0: day + date, no year, no icon, centred ────────
  //  e.g.  "   Wed, 14 May   "
  char datePart[21];
  snprintf(datePart, 21, "%s, %02d %s",
           DOW_N[ct_dow], ct_day, MON_N[ct_month]);
  printCenter(0, datePart);

  // ── Row 1: blank (breathing space) ──────────────────────

  // ── Row 2: big spaced time  "   HH : MM  AM   " ─────────
  char timeLine[21];
  snprintf(timeLine, 21, "   %02d : %02d  %s   ",
           to12h(ct_hour), ct_minute, ampmStr(ct_hour));
  lcd.setCursor(0, 2);
  lcd.print(timeLine);

  // ── Row 3: clean button hint, no dashes ─────────────────
  //  "       [A] ▶            "  centred
  lcd.setCursor(6, 3);
  lcd.print("[A] ");
  lcd.write(2);   // ▶ play arrow
  lcd.print("  menu");
}

// ─────────────────────────────────────────────────────────────
//  MAIN MENU
//
//  ┌────────────────────┐
//  │  ====  MENU  ====  │
//  │  ▶  Study Session  │
//  │  □  Exercise Mode  │
//  │[A]↕      [B]↵      │
//  └────────────────────┘
//
//  Row 3 hint:  [A] ↕   (scroll)    [B] ↵  (confirm/enter)
// ─────────────────────────────────────────────────────────────
void drawMainMenu() {
  slots_Menu();
  lcd.clear();
  printCenter(0, "====  MENU  ====");

  // Row 1 — Study Session
  lcd.setCursor(2, 1);
  lcd.write(menuCursor == 0 ? 2 : 1);   // ▶ or □
  lcd.print("  Study Session ");

  // Row 2 — Exercise Mode
  lcd.setCursor(2, 2);
  lcd.write(menuCursor == 1 ? 2 : 1);   // ▶ or □
  lcd.print("  Exercise Mode ");

  // Row 3: [A] ↕  (6 chars)  spacer  [B] ↵  (6 chars)
  lcd.setCursor(0, 3);
  lcd.print("  [A]");
  lcd.write(5);   // ↕ up-down
  lcd.print("      [B]");
  lcd.write(6);   // ↵ enter
  lcd.print("  ");
}

// ─────────────────────────────────────────────────────────────
//  SESSION DURATION SELECT
//
//  ┌────────────────────┐
//  │  == STUDY TIME ==  │
//  │  ▶   10 min        │
//  │  □   30 min        │
//  │  □   60 min        │
//  └────────────────────┘
//
//  Row 3 replaced by third option row (3 items fit rows 1-3).
//  Hint moves to a mini inline strip after the last item:
//
//  Actually: 3 items on rows 1-3, hint embedded on row 3 right side
//  when that item is NOT selected, or just shown cleanly below.
//  Since all 4 rows are needed for 3 items + header we place the
//  hint as a tiny [A]↓ [B]↵ on the RIGHT of the header row 0.
// ─────────────────────────────────────────────────────────────
void drawSessionSelect() {
  slots_Session();
  lcd.clear();

  // Row 0: header + inline mini hint on right
  lcd.setCursor(0, 0);
  lcd.print("  STUDY TIME  ");
  lcd.setCursor(14, 0);
  lcd.print("[A]");
  lcd.write(5);   // ↓ cycle
  lcd.print("[B]");
  lcd.write(6);   // ↵ confirm

  // Rows 1-3: the three duration options (no "session" word)
  const char* durations[] = {"  10 min", "  30 min", "  60 min"};
  for (int i = 0; i < 3; i++) {
    lcd.setCursor(2, i + 1);
    lcd.write(sessionCursor == i ? 2 : 1);   // ▶ selected or □ unselected
    lcd.print(durations[i]);
  }
}

// ─────────────────────────────────────────────────────────────
//  STUDY RUNNING
//
//  ┌────────────────────┐
//  │▶ ==  FOCUS MODE == │
//  │                    │
//  │      24 : 59       │
//  │[████████--------]  │
//  └────────────────────┘
//
//  Row 3: progress bar (no hint text — bar speaks for itself).
//  Hint is embedded in row 0: icon changes ▶ / ⏸ to show state.
//  Very bottom of screen: tiny [A]▶/⏸  [B]⌂  after bar on row 3.
//
//  Full layout:
//  Row 0:  ▶ ==  FOCUS MODE ==
//  Row 1:  (blank — breathing room)
//  Row 2:       24 : 59
//  Row 3:  [█████████-------]   (16 wide, 2 bracket chars = 18, +[A] hint)
// ─────────────────────────────────────────────────────────────
void drawStudyRunning() {
  slots_Timer();
  long total   = sessionOptions[sessionCursor] * 60L;
  long remaining = studyTotalSeconds;
  int  filled  = (int)(((total - remaining) * 16L) / total);

  lcd.clear();

  // ── Row 0: state icon + header ──────────────────────────
  lcd.setCursor(0, 0);
  lcd.write(studyPaused ? 3 : 2);   // ⏸ or ▶
  lcd.print(" ==  FOCUS MODE ==");

  // ── Row 1: blank (breathing space) ──────────────────────

  // ── Row 2: big spaced countdown ─────────────────────────
  char cntLine[21];
  snprintf(cntLine, 21, "     %02d : %02d      ",
           (int)(remaining/60), (int)(remaining%60));
  lcd.setCursor(0, 2);
  lcd.print(cntLine);

  // ── Row 3: progress bar + tiny hint ─────────────────────
  lcd.setCursor(1, 3);
  lcd.print("[");
  for (int i = 0; i < 14; i++) lcd.write(i < filled ? 0 : 1);
  lcd.print("]");
  // tiny [A] and [B⌂] hint squeezed after bar (cols 17-19)
  lcd.setCursor(17, 3);
  lcd.write(studyPaused ? 2 : 3);   // show what A will DO (toggle)
  lcd.print(" ");
  lcd.write(7);   // ⌂ home (B long)
}

// ─────────────────────────────────────────────────────────────
//  EXERCISE RUNNING
//
//  ┌────────────────────┐
//  │♪ == EXERCISE == ♪  │
//  │                    │
//  │    Jack  Squats    │
//  │      09 : 33       │
//  └────────────────────┘
//
//  Row 0: ♪ header ♪
//  Row 1: blank (or "-- PAUSED --" when paused)
//  Row 2: centred exercise name
//  Row 3: big countdown  +  tiny state/home icons right-aligned
// ─────────────────────────────────────────────────────────────
void drawExerciseRunning() {
  slots_Exercise();

  int idx = 0;
  for (int i = 0; i < NUM_EXERCISES; i++) {
    if (exerciseElapsed >= exercises[i].atSecond) idx = i; else break;
  }
  long remaining = EXERCISE_TOTAL - exerciseElapsed;

  lcd.clear();

  // ── Row 0: ♪ header ♪ ───────────────────────────────────
  lcd.setCursor(0, 0);
  lcd.write(5);   // ♪
  lcd.print(" == EXERCISE ==");
  lcd.setCursor(19, 0);
  lcd.write(5);   // ♪

  // ── Row 1: exercise name or PAUSED ──────────────────────
  if (exercisePaused) {
    printCenter(1, "- - PAUSED - -");
  } else {
    printCenter(1, exercises[idx].name);
  }

  // ── Row 2: blank (breathing space when not paused) ──────
  // already blank from lcd.clear()

  // ── Row 3: countdown + tiny icons right ─────────────────
  char cntLine[21];
  snprintf(cntLine, 21, "   %02d : %02d",
           (int)(remaining/60), (int)(remaining%60));
  lcd.setCursor(0, 3);
  lcd.print(cntLine);
  // icons at cols 14-19:  [A icon] space [B⌂]
  lcd.setCursor(14, 3);
  lcd.print("  ");
  lcd.write(exercisePaused ? 2 : 3);   // show what A will DO
  lcd.print("  ");
  lcd.write(7);   // ⌂ home
}

// ─────────────────────────────────────────────────────────────
//  DONE SCREEN
//
//  ┌────────────────────┐
//  │  - - - - - - - - - │
//  │  ♥  Well Done!  ♥  │
//  │  Amazing effort :) │
//  │    Press any btn   │
//  └────────────────────┘
// ─────────────────────────────────────────────────────────────
void drawDone() {
  lcd.clear();
  printCenter(0, "- - - - - - - -");
  lcd.setCursor(2, 1);
  lcd.write(4);
  lcd.print(doneIsExercise ? "  Well Done!   " : "  Session Done!");
  lcd.write(4);
  printCenter(2, "Amazing effort :)");
  printCenter(3, "-- Press any btn --");
}

// ════════════════════════════════════════════════════════════
//  STATE TRANSITIONS
// ════════════════════════════════════════════════════════════
void goToHome() {
  appState = STATE_HOME_CLOCK;
  lastClockUpdate = 0;
  drawHomeClock();
}

void goToMainMenu() {
  appState = STATE_MAIN_MENU;
  menuCursor = 0;
  drawMainMenu();
}

void startStudy() {
  studyTotalSeconds = sessionOptions[sessionCursor] * 60L;
  studyRunning = true; studyPaused = false;
  studyPrevMillis = millis();
  appState = STATE_STUDY_RUNNING;
  drawStudyRunning();
}

void startExercise() {
  exerciseElapsed = 0;
  exerciseRunning = true; exercisePaused = false;
  exercisePrevMillis = millis();
  appState = STATE_EXERCISE_RUNNING;
  drawExerciseRunning();
}

// ════════════════════════════════════════════════════════════
//  SETUP
// ════════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  Wire.begin(4, 16);

  pinMode(BTN_A, INPUT_PULLUP);
  pinMode(BTN_B, INPUT_PULLUP);

  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);

  lcd.init();
  lcd.backlight();
  loadPermanentChars();   // load slots 0-4 once at boot

  drawSplash();
  sfx_BootMelody();       // plays over the splash screen
  delay(3000);

  if (rtc.begin() && !rtc.lostPower()) {
    timeSource = TS_RTC;
    goToHome();
    return;
  }

  startHotspot();
  appState = STATE_TIME_SYNC_AP;
  drawTimeSyncAP();
}

// ════════════════════════════════════════════════════════════
//  LOOP
// ════════════════════════════════════════════════════════════
void loop() {
  bool aShort, aLong, bShort, bLong;
  handleBtn(BTN_A, btnA_pt, btnA_held, btnA_proc, aShort, aLong);
  handleBtn(BTN_B, btnB_pt, btnB_held, btnB_proc, bShort, bLong);

  switch (appState) {

    case STATE_TIME_SYNC_AP:
      server.handleClient();
      if (timeSynced) { stopHotspot(); drawSyncDone(); delay(2000); goToHome(); }
      if (bLong) { sfx_Back(); stopHotspot(); swEpoch=0; swMillis=millis(); timeSource=TS_SOFTWARE; goToHome(); }
      break;

    case STATE_HOME_CLOCK: {
      unsigned long now = millis();
      if (now - lastClockUpdate >= 1000) { lastClockUpdate = now; drawHomeClock(); }
      if (aShort) { sfx_Confirm(); goToMainMenu(); }
      break;
    }

    case STATE_MAIN_MENU:
      if (aShort) { sfx_Navigate(); menuCursor=(menuCursor+1)%2; drawMainMenu(); }
      if (bShort) {
        sfx_Confirm();
        if (menuCursor==0) { sessionCursor=0; appState=STATE_SESSION_SELECT; drawSessionSelect(); }
        else startExercise();
      }
      if (bLong) { sfx_Back(); goToHome(); }
      break;

    case STATE_SESSION_SELECT:
      if (aShort) { sfx_Navigate(); sessionCursor=(sessionCursor+1)%3; drawSessionSelect(); }
      if (bShort) { sfx_Confirm(); startStudy(); }
      if (bLong)  { sfx_Back(); goToMainMenu(); }
      break;

    case STATE_STUDY_RUNNING:
      if (aShort) {
        studyPaused = !studyPaused;
        if (!studyPaused) { sfx_Resume(); studyPrevMillis = millis(); }
        else              { sfx_Pause(); }
        drawStudyRunning();
      }
      if (bLong) { sfx_Back(); studyRunning=studyPaused=false; goToHome(); }
      if (studyRunning && !studyPaused) {
        unsigned long now = millis();
        if (now - studyPrevMillis >= 1000) {
          studyPrevMillis = now;
          if (studyTotalSeconds > 0) { studyTotalSeconds--; drawStudyRunning(); }
          else { sfx_Done(); studyRunning=false; doneIsExercise=false; appState=STATE_DONE; drawDone(); }
        }
      }
      break;

    case STATE_EXERCISE_RUNNING:
      if (aShort) {
        exercisePaused = !exercisePaused;
        if (!exercisePaused) { sfx_Resume(); exercisePrevMillis = millis(); }
        else                 { sfx_Pause(); }
        drawExerciseRunning();
      }
      if (bLong) { sfx_Back(); exerciseRunning=exercisePaused=false; goToHome(); }
      if (exerciseRunning && !exercisePaused) {
        unsigned long now = millis();
        if (now - exercisePrevMillis >= 1000) {
          exercisePrevMillis = now;
          if (exerciseElapsed < EXERCISE_TOTAL) {
            exerciseElapsed++;

            // Detect exercise boundary — chime when the move changes
            int prevIdx = 0, newIdx = 0;
            for (int i = 0; i < NUM_EXERCISES; i++) {
              if ((exerciseElapsed - 1) >= exercises[i].atSecond) prevIdx = i; else break;
            }
            for (int i = 0; i < NUM_EXERCISES; i++) {
              if (exerciseElapsed >= exercises[i].atSecond) newIdx = i; else break;
            }
            if (newIdx != prevIdx) sfx_ExerciseChange();

            drawExerciseRunning();
          } else {
            sfx_Done();
            exerciseRunning=false; doneIsExercise=true; appState=STATE_DONE; drawDone();
          }
        }
      }
      break;

    case STATE_DONE:
      if (aShort || bShort || aLong || bLong) { sfx_ButtonClick(); goToHome(); }
      break;

    default: break;
  }
}
