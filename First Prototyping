// SAVE CONFIG
void handleSave() {
  if(!server.hasArg("plain")){server.send(400,"text/plain","No body");return;}
  String body=server.arg("plain");
  int si=body.indexOf("\"s\":[");
  if(si>=0){si+=5;for(int k=0;k<3;k++){int end=body.indexOf(k<2?',':']',si);if(end<0)break;int v=body.substring(si,end).toInt();if(v>=1&&v<=180)sessionMins[k]=v;si=end+1;}}
  int exCount=0,pos=body.indexOf("\"exercises\":[");
  if(pos>=0){pos+=13;while(exCount<MAX_EXERCISES){
    int os=body.indexOf('{',pos);if(os<0)break;int oe=body.indexOf('}',os);if(oe<0)break;
    String obj=body.substring(os,oe+1);
    int ni=obj.indexOf("\"name\":\"");String nm="Exercise";
    if(ni>=0){ni+=8;int ne=ni;while(ne<(int)obj.length()&&!(obj[ne]=='"'&&obj[ne-1]!='\\'))ne++;nm=obj.substring(ni,ne);nm.replace("\\\"","\"");}
    int di=obj.indexOf("\"dur\":");int dur=30;
    if(di>=0){di+=6;int de=di;while(de<(int)obj.length()&&obj[de]>='0'&&obj[de]<='9')de++;dur=obj.substring(di,de).toInt();if(dur<5)dur=5;if(dur>600)dur=600;}
    strncpy(exList[exCount].name,nm.c_str(),MAX_NAME_LEN);exList[exCount].name[MAX_NAME_LEN]='\0';
    exList[exCount].durationSec=dur;exCount++;pos=oe+1;
  }}
  if(exCount>0)numExercises=exCount;
  computeStartTimes();saveConfig();setupSaved=true;
  server.send(200,"text/plain","OK");
}

// ALARMS JSON
void handleAlarmsJson() {
  String j="[";
  for(int i=0;i<numAlarms;i++){
    if(i>0)j+=",";
    j+="{\"label\":\"";
    for(int c=0;alarms[i].label[c];c++){char ch=alarms[i].label[c];if(ch=='"')j+="\\\"";else j+=ch;}
    j+="\",\"enabled\":"+(alarms[i].enabled?String("true"):String("false"));
    j+=",\"type\":";j+=alarms[i].type;
    j+=",\"hour\":";j+=alarms[i].hour;
    j+=",\"minute\":";j+=alarms[i].minute;
    j+=",\"dow\":";j+=alarms[i].dayOfWeek;j+="}";
  }
  j+="]"; server.send(200,"application/json",j);
}

// SAVE ALARMS
void handleSaveAlarms() {
  if(!server.hasArg("plain")){server.send(400,"text/plain","No body");return;}
  String body=server.arg("plain");
  int count=0,pos=0;
  while(count<MAX_ALARMS){
    int os=body.indexOf('{',pos);if(os<0)break;int oe=body.indexOf('}',os);if(oe<0)break;
    String obj=body.substring(os,oe+1);
    // parse each field
    auto getStr=[&](const char*key)->String{
      int p=obj.indexOf(key);if(p<0)return "";p+=strlen(key);
      if(obj[p]=='"'){p++;int e=p;while(e<(int)obj.length()&&!(obj[e]=='"'&&obj[e-1]!='\\'))e++;return obj.substring(p,e);}
      return "";
    };
    auto getInt=[&](const char*key)->int{
      int p=obj.indexOf(key);if(p<0)return 0;p+=strlen(key);
      while(p<(int)obj.length()&&(obj[p]==' '||obj[p]=='"'))p++;
      int e=p;while(e<(int)obj.length()&&(obj[e]>='0'&&obj[e]<='9'))e++;
      return obj.substring(p,e).toInt();
    };
    auto getBool=[&](const char*key)->bool{int p=obj.indexOf(key);if(p<0)return false;return obj.indexOf("true",p+strlen(key))>=0;};

    String lbl=getStr("\"label\":\""); lbl.replace("\\\"","\"");
    if(lbl.length()==0)lbl="Alarm";
    strncpy(alarms[count].label,lbl.c_str(),ALARM_LABEL_LEN); alarms[count].label[ALARM_LABEL_LEN]='\0';
    alarms[count].enabled  =getBool("\"enabled\":");
    alarms[count].type     =(uint8_t)getInt("\"type\":");
    alarms[count].hour     =(uint8_t)getInt("\"hour\":");
    alarms[count].minute   =(uint8_t)getInt("\"minute\":");
    alarms[count].dayOfWeek=(uint8_t)getInt("\"dow\":");
    count++;pos=oe+1;
  }
  numAlarms=count;
  saveAlarms();
  server.send(200,"text/plain","OK");
}


