void saveConfig() {
  prefs.begin("sm", false);
  prefs.putInt("numEx", numExercises);
  for (int i = 0; i < numExercises; i++) {
    char kN[10], kD[10];
    snprintf(kN,10,"eN%d",i); snprintf(kD,10,"eD%d",i);
    prefs.putString(kN, exList[i].name);
    prefs.putInt(kD, exList[i].durationSec);
  }
  prefs.putInt("s0", sessionMins[0]);
  prefs.putInt("s1", sessionMins[1]);
  prefs.putInt("s2", sessionMins[2]);
  prefs.putInt("tz", (int)g_tzOffsetSec);
  prefs.end();
}

void saveAlarms() {
  prefs.begin("smal", false);
  prefs.putInt("num", numAlarms);
  for (int i = 0; i < numAlarms; i++) {
    char k[12];
    snprintf(k,12,"a%d",i);
    // Pack: enabled(1) type(1) hour(1) min(1) dow(1) label(...)
    uint8_t buf[5 + ALARM_LABEL_LEN + 1];
    buf[0] = alarms[i].enabled ? 1 : 0;
    buf[1] = alarms[i].type;
    buf[2] = alarms[i].hour;
    buf[3] = alarms[i].minute;
    buf[4] = alarms[i].dayOfWeek;
    memcpy(buf+5, alarms[i].label, ALARM_LABEL_LEN+1);
    prefs.putBytes(k, buf, sizeof(buf));
  }
  prefs.end();
}

void loadAlarms() {
  prefs.begin("smal", true);
  numAlarms = prefs.getInt("num", 0);
  if (numAlarms < 0 || numAlarms > MAX_ALARMS) numAlarms = 0;
  for (int i = 0; i < numAlarms; i++) {
    char k[12]; snprintf(k,12,"a%d",i);
    uint8_t buf[5 + ALARM_LABEL_LEN + 1];
    memset(buf, 0, sizeof(buf));
    prefs.getBytes(k, buf, sizeof(buf));
    alarms[i].enabled   = buf[0] != 0;
    alarms[i].type      = buf[1];
    alarms[i].hour      = buf[2];
    alarms[i].minute    = buf[3];
    alarms[i].dayOfWeek = buf[4];
    memcpy(alarms[i].label, buf+5, ALARM_LABEL_LEN+1);
    alarms[i].label[ALARM_LABEL_LEN] = '\0';
  }
  prefs.end();
}

void loadConfig() {
  prefs.begin("sm", true);
  int n = prefs.getInt("numEx", -1);
  if (n < 1 || n > MAX_EXERCISES) { prefs.end(); loadDefaults(); }
  else {
    numExercises = n;
    for (int i = 0; i < numExercises; i++) {
      char kN[10], kD[10];
      snprintf(kN,10,"eN%d",i); snprintf(kD,10,"eD%d",i);
      String s = prefs.getString(kN,"Exercise");
      strncpy(exList[i].name, s.c_str(), MAX_NAME_LEN); exList[i].name[MAX_NAME_LEN]='\0';
      exList[i].durationSec = prefs.getInt(kD,30);
    }
    sessionMins[0] = prefs.getInt("s0",10);
    sessionMins[1] = prefs.getInt("s1",30);
    sessionMins[2] = prefs.getInt("s2",60);
    g_tzOffsetSec  = (int32_t)prefs.getInt("tz",0);
    prefs.end();
    computeStartTimes();
  }
  loadAlarms();
}


