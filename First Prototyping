void printCenter(int row, const char* txt) {
  int len = (int)strlen(txt);
  int col = (20 - len) / 2;
  if (col < 0) col = 0;
  lcd.setCursor(col, row);
  lcd.print(txt);
}

void pad2(int v) { if (v < 10) lcd.print("0"); lcd.print(v); }

void printCountdown(int row, int col, long secs) {
  lcd.setCursor(col, row);
  pad2((int)(secs/60)); lcd.print(":"); pad2((int)(secs%60));
}

