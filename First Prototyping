const unsigned long LONG_PRESS = 700;
const unsigned long DEBOUNCE   = 50;

void handleBtn(int pin, unsigned long &pt, bool &held, bool &proc,
               bool &sOut, bool &lOut) {
  sOut = false; lOut = false;
  if (digitalRead(pin) == LOW) {
    if (!held) { held=true; proc=false; pt=millis(); }
    else if (!proc && millis()-pt >= LONG_PRESS) { lOut=true; proc=true; }
  } else {
    if (held) {
      if (!proc && millis()-pt >= DEBOUNCE) sOut=true;
      held=false; proc=false;
    }
  }
}

// ════════════════════════════════════════════════════════════
//  LCD UTILITIES
