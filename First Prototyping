// ════════════════════════════════════════════════════════════
//  TIMEZONE  (fix for 1-hour offset)
//
//  The browser sends:
//    epoch      = Math.floor(Date.now() / 1000)   ← UTC epoch
//    tzOffset   = -new Date().getTimezoneOffset()  ← local offset in MINUTES
//                 (e.g. Lagos UTC+1 → tzOffset = 60)
//
//  We add tzOffset*60 to the epoch before storing, so the
//  device always works in local time internally.
//  decodeEpoch() uses gmtime_r (treats stored value as "UTC")
//  which then gives correct LOCAL hours/minutes.
// ════════════════════════════════════════════════════════════
int32_t g_tzOffsetSec = 0;   // loaded from flash, updated on sync


