// ════════════════════════════════════════════════════════════
//  TIME SOURCE
// ════════════════════════════════════════════════════════════
enum TimeSource { TS_NONE, TS_RTC, TS_SOFTWARE };
TimeSource timeSource = TS_NONE;
time_t   swEpoch  = 0;
uint32_t swMillis = 0;

time_t nowEpoch() {
  if (timeSource==TS_RTC) return (time_t)rtc.now().unixtime();
  return swEpoch + (time_t)((millis()-swMillis)/1000UL);
}

uint16_t ct_year; uint8_t ct_month,ct_day,ct_hour,ct_minute,ct_second,ct_dow;
void decodeEpoch(time_t ep) {
  struct tm t; gmtime_r(&ep,&t);
  ct_year=(uint16_t)(t.tm_year+1900); ct_month=(uint8_t)(t.tm_mon+1);
  ct_day=(uint8_t)t.tm_mday; ct_hour=(uint8_t)t.tm_hour;
  ct_minute=(uint8_t)t.tm_min; ct_second=(uint8_t)t.tm_sec; ct_dow=(uint8_t)t.tm_wday;
}


