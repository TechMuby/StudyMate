  lcd.backlight();

  loadConfig();   // load from flash (or defaults)

  slots_Done();
  drawSplash();
  sfx_BootMelody();
  delay(3000);

  if (rtc.begin()&&!rtc.lostPower()){
    timeSource=TS_RTC; goToHome(); return;
  }

