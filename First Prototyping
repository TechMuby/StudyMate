//
//   S C R E E N   D E S I G N S
//
//  Button hint row convention (row 3 on every screen):
//
//    [A] icon  description    [B] icon  description
//
//    "A" and "B" are the physical button labels on the PCB.
//    Icons are custom chars drawn inline — no word like
//    "next", "back", "open", "select" ever appears.
//
//  Icon legend used in hints:
//    ↕  (#5) = scroll / move cursor
//    ↓  (#5) = cycle down through options
//    ↵  (#6) = confirm / enter / select
//    ←  (#7) = go back one screen
//    ⌂  (#7) = go all the way home
//
// ════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────
//  SPLASH
//
//  ┌────────────────────┐
//  │                    │
//  │   ♥ StudyMate ♥    │
//  │  Your Focus Partner│
//  │                    │
//  └────────────────────┘
// ─────────────────────────────────────────────────────────────
void drawSplash() {
  lcd.clear();
  // heart is slot #4, always permanent — safe to use inline
  lcd.setCursor(4, 1);
  lcd.write(4); lcd.print(" StudyMate "); lcd.write(4);
  printCenter(2, "Your Focus Partner");
}

