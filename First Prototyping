//  RUNTIME CONFIG  (loaded from flash, edited via portal)
// ════════════════════════════════════════════════════════════
struct ExerciseMove {
  char name[MAX_NAME_LEN + 1];
  int  durationSec;   // how long this exercise lasts
};

// Working copies — modified by portal, persisted to flash
int           numExercises = 0;
ExerciseMove  exList[MAX_EXERCISES];
int           sessionMins[3];   // e.g. {10, 30, 60}

// Computed from exList — atSecond[i] = when exercise i starts
int atSecond[MAX_EXERCISES];

void computeStartTimes() {
  int t = 0;
  for (int i = 0; i < numExercises; i++) {
    atSecond[i] = t;
    t += exList[i].durationSec;
  }
}

int totalExerciseSec() {
  int t = 0;
  for (int i = 0; i < numExercises; i++) t += exList[i].durationSec;
  return t;
}

// ── Factory defaults ─────────────────────────────────────────
void loadDefaults() {
  sessionMins[0] = 10;
  sessionMins[1] = 30;
  sessionMins[2] = 60;

  const char* dNames[] = {
    "Get Ready!","Jack Squats","Push-Ups","Caterpillars",
    "Inch Worms","Elbow Plank","Cat Stretch","Wats Up Dawg",
    "Heel Tap Crunch","Hip Thrust","Squat+Calf Raise",
    "Eagle Walks","Upright Plank","Hamstring Stretch",
    "Superman Strokes","Neg. Push-Ups","Hip Stretch Lunge",
    "Squat Taps","Jumping Jacks"
  };
  const int dDur[] = {
    27,30,30,30,30,30,30,30,30,30,
    60,30,30,60,30,30,30,30,30
  };
  numExercises = 19;
  for (int i = 0; i < numExercises; i++) {
    strncpy(exList[i].name, dNames[i], MAX_NAME_LEN);
    exList[i].name[MAX_NAME_LEN] = '\0';
    exList[i].durationSec = dDur[i];
  }
  computeStartTimes();
}

// ── Flash persistence ────────────────────────────────────────
void saveConfig() {
  prefs.begin("studymate", false);
  prefs.putInt("numEx", numExercises);
  for (int i = 0; i < numExercises; i++) {
    char kName[12], kDur[12];
    snprintf(kName, 12, "exN%d", i);
    snprintf(kDur,  12, "exD%d", i);
    prefs.putString(kName, exList[i].name);
    prefs.putInt(kDur, exList[i].durationSec);
  }
  prefs.putInt("s0", sessionMins[0]);
  prefs.putInt("s1", sessionMins[1]);
  prefs.putInt("s2", sessionMins[2]);
  prefs.end();
}

void loadConfig() {
  prefs.begin("studymate", true);
  int n = prefs.getInt("numEx", -1);
  if (n < 1 || n > MAX_EXERCISES) {
    prefs.end();
    loadDefaults();
    return;
  }
  numExercises = n;
  for (int i = 0; i < numExercises; i++) {
    char kName[12], kDur[12];
    snprintf(kName, 12, "exN%d", i);
    snprintf(kDur,  12, "exD%d", i);
    String s = prefs.getString(kName, "Exercise");
    strncpy(exList[i].name, s.c_str(), MAX_NAME_LEN);
    exList[i].name[MAX_NAME_LEN] = '\0';
    exList[i].durationSec = prefs.getInt(kDur, 30);
  }
  sessionMins[0] = prefs.getInt("s0", 10);
  sessionMins[1] = prefs.getInt("s1", 30);
  sessionMins[2] = prefs.getInt("s2", 60);
  prefs.end();
  computeStartTimes();
}


