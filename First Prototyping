byte icnEnter[8] = {0x01,0x01,0x05,0x09,0x1F,0x08,0x04,0x00}; // ↵  confirm
byte icnBack[8]  = {0x04,0x08,0x1F,0x08,0x04,0x00,0x00,0x00}; // ←  back
byte icnHome[8]  = {0x04,0x0E,0x1F,0x11,0x11,0x1F,0x00,0x00}; // ⌂  home
byte icnNote[8]  = {0x01,0x03,0x05,0x09,0x1B,0x1B,0x12,0x00}; // ♪  music
byte icnCheck[8] = {0x00,0x01,0x01,0x02,0x14,0x08,0x00,0x00}; // ✓  check
byte icnClock[8] = {0x0E,0x11,0x15,0x17,0x11,0x0E,0x00,0x00}; // ⊙  clock

// Load permanent chars at boot
void loadPermanentChars() {
  lcd.createChar(0, charSolid);
  lcd.createChar(1, charHollow);
  lcd.createChar(2, charPlay);
  lcd.createChar(3, charPause);
  lcd.createChar(4, charHeart);
}

// ── Slot helpers — call before drawing the relevant screen ──
// After lcd.createChar() you MUST do lcd.setCursor() or lcd.home()
// before writing, otherwise the cursor stays in CGRAM mode.

// Menu screens: [↕]A  [↵]B  [←]B-long
void slots_Menu() {
  lcd.createChar(5, icnUpDn);
  lcd.createChar(6, icnEnter);
  lcd.createChar(7, icnBack);
  lcd.home();
}

// Session select: [↓]A  [↵]B  [←]B-long
void slots_Session() {
  lcd.createChar(5, icnDown);
  lcd.createChar(6, icnEnter);
  lcd.createChar(7, icnBack);
  lcd.home();
}

// Timer screens (study/exercise): [▶/⏸]A  [⌂]B-long
// (▶ = slot2, ⏸ = slot3 already permanent — only need ⌂)
void slots_Timer() {
  lcd.createChar(7, icnHome);
  lcd.home();
}

// Home clock screen: ⊙ clock header
void slots_Home() {
  lcd.createChar(5, icnClock);
  lcd.home();
}

// Sync screens: ♪ note, ✓ check
void slots_Sync() {
  lcd.createChar(5, icnNote);
  lcd.createChar(6, icnCheck);
  lcd.home();
}

// Exercise header: ♪ note
void slots_Exercise() {
  lcd.createChar(5, icnNote);
  lcd.createChar(7, icnHome);
  lcd.home();
}

// ════════════════════════════════════════════════════════════
//  BUZZER
//  Passive buzzer on GPIO 19.
//  All sounds are non-blocking except the boot melody and
//  the exercise-change chime, which are short enough (~300ms)
//  that they don't affect UX.
// ════════════════════════════════════════════════════════════
#define BUZZER_PIN 19

// ── Low-level tone helpers ──────────────────────────────────
// Play a single note: frequency in Hz, duration in ms.
// freq = 0 → silence (rest).
void buzzNote(int freq, int dur) {
  if (freq > 0) {
    tone(BUZZER_PIN, freq, dur);
  } else {
    noTone(BUZZER_PIN);
  }
  delay(dur);
}

// Same as buzzNote but adds a small gap after so notes
// don't bleed into each other (legato vs staccato feel).
void buzzNoteGap(int freq, int dur, int gap = 30) {
  buzzNote(freq, dur);
  noTone(BUZZER_PIN);
  delay(gap);
}

// ── Note frequency constants ────────────────────────────────
#define NOTE_C4  262
#define NOTE_D4  294
#define NOTE_E4  330
#define NOTE_F4  349
#define NOTE_G4  392
#define NOTE_A4  440
#define NOTE_B4  494
#define NOTE_C5  523
#define NOTE_D5  587
#define NOTE_E5  659
#define NOTE_F5  698
#define NOTE_G5  784
#define NOTE_A5  880
#define NOTE_REST  0

// ════════════════════════════════════════════════════════════
//  SOUND EFFECTS
// ════════════════════════════════════════════════════════════

// ── 1. Button click — short, snappy, non-intrusive ──────────
//  A crisp 2ms tick at 1800Hz. Barely audible but tactile.
void sfx_ButtonClick() {
  tone(BUZZER_PIN, 1800, 18);
  // No delay — returns immediately so UI stays responsive.
  // The tone() call handles the timing in the background.
}

// ── 2. Navigate / scroll — slightly lower than click ────────
//  Used when cursor moves between menu items.
void sfx_Navigate() {
  tone(BUZZER_PIN, 1200, 25);
}

// ── 3. Confirm / select — two-note ascending pop ────────────
//  Used when an option is confirmed (B press to start/select).
void sfx_Confirm() {
  buzzNoteGap(NOTE_E5, 60, 20);
  buzzNoteGap(NOTE_G5, 80, 0);
}

// ── 4. Back / cancel — descending two-note ──────────────────
void sfx_Back() {
  buzzNoteGap(NOTE_G4, 60, 20);
  buzzNoteGap(NOTE_E4, 80, 0);
}

// ── 5. Pause — single dull thud ─────────────────────────────
void sfx_Pause() {
  tone(BUZZER_PIN, 400, 120);
}

// ── 6. Resume — bright single note ──────────────────────────
void sfx_Resume() {
  tone(BUZZER_PIN, NOTE_A5, 80);
}

// ── 7. Exercise change chime ─────────────────────────────────
//  A short 3-note ascending chime. Signals next move.
//  Total duration ~270ms — fast enough to not feel intrusive.
void sfx_ExerciseChange() {
  buzzNoteGap(NOTE_C5, 70, 25);
  buzzNoteGap(NOTE_E5, 70, 25);
  buzzNoteGap(NOTE_G5, 110, 0);
}

// ── 8. Session / exercise complete ───────────────────────────
//  Triumphant 4-note fanfare.
void sfx_Done() {
  buzzNoteGap(NOTE_C5, 100, 20);
  buzzNoteGap(NOTE_E5, 100, 20);
  buzzNoteGap(NOTE_G5, 100, 20);
  buzzNoteGap(NOTE_C5, 250, 0);  // high C hold
}

// ── 9. Boot melody ────────────────────────────────────────────
//  Plays during the 3-second splash screen.
//  A cheerful 8-note tune that feels welcoming.
//  Uses the full 3s window (notes + gaps ≈ 2.8s total).
void sfx_BootMelody() {
  // "Do Re Mi" ascending flourish → resolve
  //  C4  E4  G4  C5  |  G4  A4  G4  |  E4  C4
  buzzNoteGap(NOTE_C4, 160, 40);
  buzzNoteGap(NOTE_E4, 160, 40);
  buzzNoteGap(NOTE_G4, 160, 40);
  buzzNoteGap(NOTE_C5, 280, 60);   // peak — held longer
  buzzNoteGap(NOTE_G4, 130, 30);
  buzzNoteGap(NOTE_A4, 130, 30);
  buzzNoteGap(NOTE_G4, 130, 30);
  buzzNoteGap(NOTE_E4, 130, 30);
  buzzNoteGap(NOTE_C4, 260, 0);   // landing note
  // Total ≈ 160+40 +160+40 +160+40 +280+60 +130+30*4 +260 = ~1780ms
  // Leaves ~1.2s of silence before splash clears — feels natural.
}

// ════════════════════════════════════════════════════════════
//  TIME SOURCE
// ════════════════════════════════════════════════════════════
enum TimeSource { TS_NONE, TS_RTC, TS_SOFTWARE };
TimeSource timeSource = TS_NONE;

time_t   swEpoch  = 0;
uint32_t swMillis = 0;

time_t nowEpoch() {
  if (timeSource == TS_RTC) return (time_t)rtc.now().unixtime();
  return swEpoch + (time_t)((millis() - swMillis) / 1000UL);
}

uint16_t ct_year;
uint8_t  ct_month, ct_day, ct_hour, ct_minute, ct_second, ct_dow;

void decodeEpoch(time_t ep) {
  struct tm t;
  gmtime_r(&ep, &t);
  ct_year   = (uint16_t)(t.tm_year + 1900);
  ct_month  = (uint8_t)(t.tm_mon  + 1);
  ct_day    = (uint8_t)t.tm_mday;
  ct_hour   = (uint8_t)t.tm_hour;
  ct_minute = (uint8_t)t.tm_min;
  ct_second = (uint8_t)t.tm_sec;
  ct_dow    = (uint8_t)t.tm_wday;
}

