// ════════════════════════════════════════════════════════════
//  TIME SOURCE
// ════════════════════════════════════════════════════════════
enum TimeSource{TS_NONE,TS_RTC,TS_SOFTWARE};
TimeSource timeSource=TS_NONE;
time_t   swEpoch=0;
uint32_t swMillis=0;

// Returns LOCAL epoch (already offset-corrected)
time_t nowEpoch(){
  if(timeSource==TS_RTC) return (time_t)rtc.now().unixtime();
  return swEpoch+(time_t)((millis()-swMillis)/1000UL);
}

uint16_t ct_year; uint8_t ct_month,ct_day,ct_hour,ct_minute,ct_second,ct_dow;
void decodeEpoch(time_t ep){
  struct tm t; gmtime_r(&ep,&t);
  ct_year  =(uint16_t)(t.tm_year+1900); ct_month=(uint8_t)(t.tm_mon+1);
  ct_day   =(uint8_t)t.tm_mday;         ct_hour =(uint8_t)t.tm_hour;
  ct_minute=(uint8_t)t.tm_min;          ct_second=(uint8_t)t.tm_sec;
  ct_dow   =(uint8_t)t.tm_wday;
}


// ════════════════════════════════════════════════════════════
//  ALARM CHECKER  — call once per second from loop
// ════════════════════════════════════════════════════════════
void checkAlarms(){
  if(alarmFiring) return;
  if(ct_hour==lastCheckedHour && ct_minute==lastCheckedMin) return;
  lastCheckedHour=ct_hour; lastCheckedMin=ct_minute;

  for(int i=0;i<numAlarms;i++){
    if(!alarms[i].enabled) continue;
    if(alarms[i].hour!=ct_hour||alarms[i].minute!=ct_minute) continue;
    bool fire=false;
    switch(alarms[i].type){
      case 0: fire=(alarms[i].dayOfWeek==ct_dow); break; // once — match day
      case 1: fire=true; break;                           // daily — always
      case 2: fire=(alarms[i].dayOfWeek==ct_dow); break; // weekly
    }
    if(fire){
      alarmFiring=true;
      firingAlarmIdx=i;
      alarmStartMs=millis();
      if(alarms[i].type==0) alarms[i].enabled=false; // once → disable after firing
      saveAlarms();
      return;
    }
  }
}


