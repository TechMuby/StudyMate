// ════════════════════════════════════════════════════════════
//  BIG DIGIT RENDERER
// ════════════════════════════════════════════════════════════
const uint8_t DIGITS[10][6] = {
  {0,1,0, 3,5,3}, {6,0,6, 6,3,6}, {2,1,0, 3,5,6}, {1,1,0, 5,5,3},
  {0,2,0, 6,6,3}, {0,1,2, 5,5,3}, {0,1,2, 3,5,3}, {1,1,0, 6,4,6},
  {0,1,0, 3,5,3}, {0,1,0, 5,5,3},
};

void drawBigDigit(int d, int col, int topRow) {
  if (d<0||d>9) d=0;
  lcd.setCursor(col,   topRow);   lcd.write(DIGITS[d][0]);
  lcd.setCursor(col+1, topRow);   lcd.write(DIGITS[d][1]);
  lcd.setCursor(col+2, topRow);   lcd.write(DIGITS[d][2]);
  lcd.setCursor(col,   topRow+1); lcd.write(DIGITS[d][3]);
  lcd.setCursor(col+1, topRow+1); lcd.write(DIGITS[d][4]);
  lcd.setCursor(col+2, topRow+1); lcd.write(DIGITS[d][5]);
}

void drawBigTime(int left, int right, int topRow) {
  drawBigDigit(left/10,  1, topRow);
  drawBigDigit(left%10,  5, topRow);
  lcd.setCursor(9, topRow);   lcd.print(".");
  lcd.setCursor(9, topRow+1); lcd.print(".");
  drawBigDigit(right/10, 11, topRow);
  drawBigDigit(right%10, 15, topRow);
}


